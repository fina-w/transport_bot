# --- MySQL (local ou Railway) ---
# Soit variables séparées :
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=transport_demo

# Soit une seule URL (Railway « MySQL » fournit souvent MYSQL_URL ou DATABASE_URL) :
# MYSQL_URL=mysql://user:password@host:port/railway
# DATABASE_URL=mysql://user:password@host:port/railway

# --- Assistant IA ---
# Si défini, OpenAI est utilisé en priorité
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Sinon Ollama (hébergement séparé ou tunnel)
# OLLAMA_BASE_URL=https://votre-ollama.example.com
# OLLAMA_MODEL=llama3.2

# --- CORS : * ou origines séparées par des virgules (domaine du front si différent de l’API) ---
CORS_ORIGINS=*
